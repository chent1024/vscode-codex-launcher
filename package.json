{
  "name": "open-codex",
  "displayName": "Open Codex",
  "description": "Open new Codex tabs from the VS Code sidebar, status bar, and command palette.",
  "version": "0.0.1",
  "publisher": "chent",
  "icon": "media/codex-launcher.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chent1024/vscode-codex-launcher.git"
  },
  "homepage": "https://github.com/chent1024/vscode-codex-launcher#readme",
  "bugs": {
    "url": "https://github.com/chent1024/vscode-codex-launcher/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "Chat"
  ],
  "keywords": [
    "codex",
    "openai",
    "chat",
    "launcher",
    "vscode-extension"
  ],
  "activationEvents": [
    "onCommand:codexLauncher.openNewCodexChat",
    "onView:codexLauncher.sidebarView",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexLauncher",
          "title": "Open Codex",
          "icon": "media/codex-launcher.svg"
        }
      ]
    },
    "views": {
      "codexLauncher": [
        {
          "id": "codexLauncher.sidebarView",
          "name": "Launcher",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codexLauncher.openNewCodexChat",
        "title": "Open New Codex",
        "category": "Open Codex"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf coverage dist",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.96.0",
    "@vitest/coverage-v8": "^3.0.8",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.8",
    "vscode": "^1.1.37"
  }
}
